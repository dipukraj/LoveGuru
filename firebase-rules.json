{
  "rules": {
    ".read": true,
    ".write": true,
    "visitors": {
      "$visitorId": {
        ".read": "$visitorId === auth.uid || true",
        ".write": "$visitorId === auth.uid || true"
      }
    },
    "analytics": {
      ".read": true,
      ".write": true
    },
    "shayaris": {
      "$shayariId": {
        ".read": true,
        ".write": true
      }
    },
    "comments": {
      "$shayariId": {
        ".commentId": {
          ".read": true,
          ".write": true
        }
      }
    },
    "onlineVisitors": {
      ".read": true,
      ".write": true
    }
  }
}
